@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

find_dependency(kordex_bindings CONFIG REQUIRED)
find_dependency(kordex_runtime CONFIG REQUIRED)

find_dependency(vix_error CONFIG REQUIRED)
find_dependency(vix_log CONFIG REQUIRED)
find_dependency(vix_json CONFIG REQUIRED)
find_dependency(vix_fs CONFIG REQUIRED)
find_dependency(vix_path CONFIG REQUIRED)
find_dependency(vix_env CONFIG REQUIRED)
find_dependency(vix_process CONFIG REQUIRED)
find_dependency(vix_time CONFIG REQUIRED)

if(@KORDEX_STD_ENABLE_CRYPTO@)
  find_dependency(vix_crypto CONFIG REQUIRED)
endif()

if(@KORDEX_STD_ENABLE_HTTP@)
  find_dependency(vix_core CONFIG REQUIRED)
endif()

if(@KORDEX_STD_ENABLE_SOFTADASTRA@)
  find_dependency(sdk-cpp CONFIG REQUIRED)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/kordex_stdTargets.cmake")

check_required_components(kordex_std)
